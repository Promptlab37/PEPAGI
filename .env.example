# PEPAGI — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── LLM API Keys ───────────────────────────────────────────────────────────
# At least one is required. Claude is the default manager/mediator.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# ─── Platforms (optional) ────────────────────────────────────────────────────
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use the bot
TELEGRAM_ALLOWED_USERS=

# Discord bot token
DISCORD_BOT_TOKEN=

# ─── Data directory (optional) ───────────────────────────────────────────────
# Default: ~/.pepagi
# PEPAGI_DATA_DIR=/custom/path

# ─── Manager model (optional) ────────────────────────────────────────────────
# Default: claude-opus-4-5-20251101
# PEPAGI_MANAGER_MODEL=claude-opus-4-5-20251101

# ─── Cost limits (optional) ──────────────────────────────────────────────────
# Max cost per task in USD (default: 1.0)
# PEPAGI_MAX_TASK_COST=1.0
# Max cost per session in USD (default: 10.0)
# PEPAGI_MAX_SESSION_COST=10.0

# ─── Security (optional) ─────────────────────────────────────────────────────
# Comma-separated action categories requiring approval
# PEPAGI_REQUIRE_APPROVAL=file_delete,git_push,network_external
